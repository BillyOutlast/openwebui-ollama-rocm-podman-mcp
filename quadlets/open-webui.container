[Unit]
Description=Open WebUI
After=network-online.target vllm-rocm.service
Wants=network-online.target vllm-rocm.service

[Container]
ContainerName=open-webui
Image=ghcr.io/open-webui/open-webui:main
Network=ai-shared.network
PublishPort=3000:8080
Volume=%h/.local/share/open-webui:/app/backend/data:Z
Environment=OPENAI_API_BASE_URL=http://vllm-rocm:8000/v1

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
